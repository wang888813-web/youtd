{
  "build": {
    "env": {
      "NODEJS_AWS_HANDLER": "api/server.js"
    }
  },
  "functions": {
    "api/server.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/server.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}